# Telegram Bot (bắt buộc)
BOT_TOKEN=your_bot_token_from_botfather

# ─── AI Provider (chọn 1, khuyên dùng Groq) ──────────────────────────
# Groq (FREE, nhanh, quota cao) → https://console.groq.com
GROQ_API_KEY=

# Google Gemini (backup) → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Database (mặc định: data/finance.db)
DB_PATH=data/finance.db

# ─── Network (uncomment nếu cần) ─────────────────────────────────────
# PROXY_URL=socks5://127.0.0.1:1080
# CONNECT_TIMEOUT=30
# READ_TIMEOUT=30
